# Local credentials only. Do not use real cloud credentials.
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
MINIO_BUCKET=lakehouse
MINIO_ENDPOINT=http://minio:9000
MINIO_PUBLIC_ENDPOINT=http://localhost:9000

AWS_ACCESS_KEY_ID=minioadmin
AWS_SECRET_ACCESS_KEY=minioadmin
AWS_REGION=us-east-1

SPARK_MASTER_URL=spark://spark-master:7077
SPARK_DRIVER_MEMORY=2g
SPARK_EXECUTOR_MEMORY=2g
SPARK_EXECUTOR_CORES=1
# The Docker Spark image preloads Delta/S3 JARs at build time.
# Leave this blank for reliable offline demos after the image is built.
SPARK_PACKAGES=

# Comma-separated months in YYYYMM format. Keep 1-3 months for a laptop demo.
CITIBIKE_MONTHS=202401
CITIBIKE_DOWNLOAD_DIR=/opt/project/data/raw

JUPYTER_TOKEN=lakehouse
SUPERSET_SECRET_KEY=change-this-local-secret
SUPERSET_ADMIN_USER=admin
SUPERSET_ADMIN_PASSWORD=admin
SUPERSET_ADMIN_EMAIL=admin@example.com

MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001
SPARK_MASTER_WEB_PORT=8080
SPARK_WORKER_WEB_PORT=8081
JUPYTER_PORT=8888
TRINO_PORT=8085
SUPERSET_PORT=8088
